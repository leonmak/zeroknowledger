{
  "name": "membership/netflix-active-subscription",
  "version": "0.1.0",
  "status": "draft",
  "claim": "Netflix account has an active subscription plan.",
  "owner": {
    "team": "seed-library",
    "reviewed_by": "pending"
  },
  "risk": "high",
  "target": {
    "url": "https://www.netflix.com/YourAccount",
    "auth": "session",
    "tls_min": "1.2"
  },
  "extract": {
    "selector": "[data-uia='account-plan-title'], [data-uia='membership-plan'], div[class*='PlanName'], [class*='plan-selector'] [class*='selected']",
    "pattern": "(Basic|Standard|Premium|Ad-supported)",
    "transform": "match[1]",
    "notes": "Netflix uses data-uia attributes (most stable). Avoid generic class selectors. Test against https://account.netflix.com/account. Plan names vary by region; add fixtures for US, EU, APAC."
  },
  "disclose": {
    "mode": "boolean",
    "output": "netflix_subscription_active"
  },
  "redact": [
    ".account-email",
    ".member-name",
    ".payment-card",
    ".phone-number"
  ],
  "badge": {
    "label": "Netflix Member",
    "icon": "play",
    "color": "#DC2626"
  },
  "freshness": {
    "max_age_days": 30,
    "stale_after_days": 45
  },
  "tags": ["membership", "consumer", "subscription"]
}
