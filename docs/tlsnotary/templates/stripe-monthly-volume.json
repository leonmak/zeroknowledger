{
  "name": "income/stripe-monthly-volume",
  "version": "0.1.0",
  "status": "draft",
  "claim": "User processed at least 10000 USD in recent monthly Stripe volume.",
  "owner": {
    "team": "seed-library",
    "reviewed_by": "pending"
  },
  "risk": "medium",
  "target": {
    "url": "https://dashboard.stripe.com",
    "auth": "session",
    "tls_min": "1.2"
  },
  "extract": {
    "selector": "[data-testid='gross-volume'], [class*='BalanceSummary'], [class*='DashboardMetric'], .balance-value, [class*='volume']",
    "pattern": "\\$?([0-9,]+(?:\\.[0-9]{2})?)",
    "transform": "parseFloat(match[1].replace(/,/g, ''))",
    "notes": "Stripe dashboard DOM changes frequently. Validate before each notarization. Test against https://dashboard.stripe.com/dashboard. Selectors ordered by stability."
  },
  "disclose": {
    "mode": "threshold",
    "comparison": "gte",
    "value": 10000,
    "output": "stripe_monthly_volume_gte_10000"
  },
  "redact": [
    "[data-testid='account-email']",
    "[data-testid='bank-account-last4']",
    ".UserMenu",
    "meta[name='csrf-token']"
  ],
  "badge": {
    "label": "Stripe Merchant",
    "icon": "credit-card",
    "color": "#22C55E"
  },
  "freshness": {
    "max_age_days": 30,
    "stale_after_days": 45
  },
  "tags": ["income", "business", "payments"]
}
