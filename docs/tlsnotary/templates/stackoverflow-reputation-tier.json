{
  "name": "dev/stackoverflow-reputation-tier",
  "version": "0.1.0",
  "status": "draft",
  "claim": "Stack Overflow reputation is at least 1000.",
  "owner": {
    "team": "seed-library",
    "reviewed_by": "pending"
  },
  "risk": "low",
  "target": {
    "url": "https://stackoverflow.com/users/current",
    "auth": "session",
    "tls_min": "1.2"
  },
  "extract": {
    "selector": ".fs-title, .grid--cell.fs-headline1",
    "pattern": "([0-9,]+)",
    "transform": "parseInt(match[1].replace(/,/g, ''), 10)",
    "notes": "Ensure selector still resolves on responsive layouts."
  },
  "disclose": {
    "mode": "threshold",
    "comparison": "gte",
    "value": 1000,
    "output": "stackoverflow_reputation_gte_1000"
  },
  "redact": [
    ".profile-user--name",
    ".profile-user--bio",
    ".gravatar-wrapper-128",
    ".js-user-header"
  ],
  "badge": {
    "label": "Stack Overflow Trusted",
    "icon": "chat",
    "color": "#F59E0B"
  },
  "freshness": {
    "max_age_days": 90,
    "stale_after_days": 120
  },
  "tags": ["developer", "knowledge", "reputation"]
}
